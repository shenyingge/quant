# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_SIGNAL_CHANNEL=trading_signals

# 数据库配置
DATABASE_URL=sqlite:///./trading.db

# QMT配置
QMT_SESSION_ID=123456
QMT_SESSION_ID_TRADING_SERVICE=123456
QMT_SESSION_ID_T0_DAEMON=123457
QMT_SESSION_ID_T0_SYNC=123458
QMT_PATH=C:/Program Files (x86)/QMT/userdata_mini
QMT_ACCOUNT_ID=your_account_id
QMT_ACCOUNT_TYPE=STOCK

# 交易配置
ORDER_TIMEOUT_SECONDS=60
AUTO_CANCEL_ENABLED=true
ORDER_SUBMIT_TIMEOUT=10

# 飞书配置
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook-url
T0_NOTIFY_OBSERVE_SIGNALS=false
T0_BASE_POSITION=2600
T0_TACTICAL_POSITION=900
T0_TRADE_UNIT=100
T0_MAX_TRADE_VALUE=70000
T0_MIN_HOLD_MINUTES=20
T0_POSITIVE_SELL_START_TIME=09:45
T0_POSITIVE_SELL_END_TIME=11:20
T0_POSITIVE_BUYBACK_START_TIME=13:30
T0_POSITIVE_BUYBACK_END_TIME=14:56
T0_REVERSE_BUY_START_TIME=09:50
T0_REVERSE_BUY_END_TIME=13:20
T0_REVERSE_SELL_START_TIME=13:20
T0_REVERSE_SELL_END_TIME=14:56
T0_REVERSE_SELL_MIN_PROFIT=1.2
T0_REVERSE_SELL_MAX_VWAP_DISTANCE=0.5

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=./logs/trading_service.log

# 服务配置
SERVICE_NAME=QMTTradingService
MAX_RETRY_ATTEMPTS=3

# 定时服务配置
SCHEDULED_SERVICE_ENABLED=true
SERVICE_START_TIME=08:00
SERVICE_STOP_TIME=21:00
TRADING_DAY_CHECK_ENABLED=true

# Python路径配置
PYTHONPATH=.

# 备份配置
BACKUP_ENABLED=true
BACKUP_TIME=15:05
BACKUP_METHOD=local
BACKUP_FORMAT=json
BACKUP_COMPRESS=true
BACKUP_KEEP_DAYS=30
BACKUP_LOCAL_DIR=./backups

# SCP备份配置 (用于备份到Ubuntu服务器)
SCP_HOST=your.ubuntu.server.com
SCP_PORT=22
SCP_USERNAME=your_username
SCP_PASSWORD=your_password
SCP_KEY_FILE=~/.ssh/trading_backup_key
SCP_REMOTE_DIR=/data/trading_backups
