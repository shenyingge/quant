# Redis config
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_SIGNAL_CHANNEL=trading_signals

# Redis Tick缓存配置（使用独立db，不影响交易系统）
REDIS_TICK_CACHE_DB=1
REDIS_TICK_CACHE_TTL=28800

# Redis T+0信号配置
REDIS_T0_SIGNAL_KEY=t0_signal_card
REDIS_T0_SIGNAL_TTL=86400

# Database config
DATABASE_URL=sqlite:///./trading.db

# QMT config
QMT_SESSION_ID=123456
QMT_SESSION_ID_TRADING_SERVICE=123456
QMT_SESSION_ID_T0_DAEMON=123457
QMT_SESSION_ID_T0_SYNC=123458
QMT_PATH=C:/Program Files (x86)/QMT/userdata_mini
QMT_ACCOUNT_ID=your_account_id
QMT_ACCOUNT_TYPE=STOCK

# Order config
ORDER_TIMEOUT_SECONDS=60
AUTO_CANCEL_ENABLED=true
ORDER_SUBMIT_TIMEOUT=10

# Feishu config
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook-url
FEISHU_FAILURE_NOTIFY_COOLDOWN_SECONDS=300
T0_NOTIFY_OBSERVE_SIGNALS=false
T0_SAVE_SIGNAL_CARD=false
T0_BASE_POSITION=2600
T0_TACTICAL_POSITION=900
T0_TRADE_UNIT=100
T0_MAX_TRADE_VALUE=70000
T0_INTRADAY_BAR_PERIOD=5s
T0_POLL_INTERVAL_SECONDS=5
T0_SYNC_CONNECT_RETRY_ATTEMPTS=3
T0_SYNC_CONNECT_RETRY_DELAY_SECONDS=5
T0_MIN_HOLD_MINUTES=20
T0_POSITIVE_SELL_START_TIME=09:45
T0_POSITIVE_SELL_END_TIME=11:20
T0_POSITIVE_BUYBACK_START_TIME=13:30
T0_POSITIVE_BUYBACK_END_TIME=14:56
T0_REVERSE_BUY_START_TIME=09:50
T0_REVERSE_BUY_END_TIME=13:20
T0_REVERSE_SELL_START_TIME=13:20
T0_REVERSE_SELL_END_TIME=14:56
T0_REVERSE_SELL_MIN_PROFIT=1.2
T0_REVERSE_SELL_MAX_VWAP_DISTANCE=0.5

# Logging config
LOG_LEVEL=INFO
LOG_FILE=./logs/trading_service.log

# Service config
SERVICE_NAME=QMTTradingService
MAX_RETRY_ATTEMPTS=3
HEALTHCHECK_HOST=127.0.0.1
HEALTHCHECK_PORT=8780
HEALTHCHECK_TIMEOUT_SECONDS=2
HEALTHCHECK_REFRESH_INTERVAL_SECONDS=15
WATCHDOG_ENABLED=true
WATCHDOG_CHECK_INTERVAL_SECONDS=30
WATCHDOG_MIN_RESTART_INTERVAL_SECONDS=120
WATCHDOG_STATE_PATH=./output/watchdog_state.json
WATCHDOG_ENFORCE_STOP_OUTSIDE_WINDOW=true
WATCHDOG_ENABLE_TRADING_SERVICE=true
WATCHDOG_ENABLE_T0_DAEMON=true
WATCHDOG_ENABLE_T0_SYNC=true
WATCHDOG_ENABLE_META_DB_SYNC=true
WATCHDOG_TRADING_START_TIME=08:35
WATCHDOG_TRADING_STOP_TIME=21:05
WATCHDOG_T0_START_TIME=09:20
WATCHDOG_T0_STOP_TIME=15:05
WATCHDOG_T0_SYNC_TIME=15:00
WATCHDOG_META_DB_SYNC_TIME=15:10
WATCHDOG_JOB_MAX_DELAY_MINUTES=120
ACCOUNT_POSITIONS_SNAPSHOT_PATH=./output/account_positions_snapshot.json

# Scheduled service config
SCHEDULED_SERVICE_ENABLED=true
SERVICE_START_TIME=08:00
SERVICE_STOP_TIME=21:00
TRADING_DAY_CHECK_ENABLED=true
TUSHARE_TOKEN=your_tushare_token
TUSHARE_TRADE_CALENDAR_EXCHANGE=SSE

# Python path config
PYTHONPATH=.
RSYNC_BIN=rsync
SSH_BIN=ssh

# Backup config
BACKUP_ENABLED=true
BACKUP_TIME=15:05
BACKUP_METHOD=local
# BACKUP_METHOD: local / rsync
BACKUP_FORMAT=json
BACKUP_COMPRESS=true
BACKUP_KEEP_DAYS=30
BACKUP_LOCAL_DIR=./backups

# Remote backup config (rsync over SSH, key auth recommended)
SCP_HOST=your.ubuntu.server.com
SCP_PORT=22
SCP_USERNAME=your_username
SCP_PASSWORD=your_password
SCP_KEY_FILE=~/.ssh/trading_backup_key
SCP_REMOTE_DIR=/data/trading_backups

# Meta DB config
META_DB_HOST=127.0.0.1
META_DB_PORT=15432
META_DB_NAME=quant_meta
META_DB_USER=quant
META_DB_PASSWORD=change_me
META_DB_TYPE=postgresql+asyncpg
META_DB_SCHEMA=gold
META_DB_TRADING_SCHEMA=trading
